# ─────────────────────────────────────────────
# 슬롭스쿼팅 연구 파이프라인 환경 변수 설정
# 이 파일을 .env로 복사하고 값을 채워주세요:
#   cp .env.example .env
# ─────────────────────────────────────────────

# ── LLM API 키 (최소 하나 필수) ──────────────────
OPENAI_API_KEY=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
ANTHROPIC_API_KEY=z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
GOOGLE_API_KEY=AIza...

# ── 모델 선택 (기본값으로 두어도 됩니다) ──────────
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GOOGLE_MODEL=gemini-2.0-flash

# ── 실험 파라미터 ─────────────────────────────────
# 각 질문을 몇 번 반복할지 (할루시네이션 일관성 측정)
RUNS_PER_QUESTION=5

# 응답에서 추출할 최대 패키지 수
MAX_PACKAGES_PER_RESPONSE=8

# ── 동시성 / 속도 제한 ────────────────────────────
# LLM API 동시 요청 수 (API 요금 플랜에 맞게 조정)
LLM_CONCURRENCY=3

# PyPI/npm 검증 동시 요청 수
VALIDATION_CONCURRENCY=10

# LLM 요청 간 지연 시간 (초)
REQUEST_DELAY_SECONDS=1.0

# ── 저장 경로 (기본값 권장) ───────────────────────
# DB_PATH=./results/slopsquatting_research.db
# REPORT_DIR=./results/reports
